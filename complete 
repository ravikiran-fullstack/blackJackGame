#Requires -RunAsAdministrator
[CmdletBinding()]
param(
    [string]$BiosAdminPassword = "",
    [switch]$SuspendBitLockerForNextReboot,
    [switch]$ForceRestart
)

$ErrorActionPreference = "Stop"
$LogPath = Join-Path $env:TEMP "SecureBoot.log"

if (Test-Path $LogPath) { Remove-Item $LogPath -Force }
New-Item -Path $LogPath -ItemType File -Force | Out-Null

function Write-Log {
    param([string]$Message)
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $line = "[SecureBootRemediation] $timestamp $Message"
    Write-Host $line
    Add-Content -Path $LogPath -Value $line
}

function Test-IsAdmin {
    $id = [Security.Principal.WindowsIdentity]::GetCurrent()
    $p = New-Object Security.Principal.WindowsPrincipal($id)
    return $p.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

function Get-LenovoWmiObject {
    param([Parameter(Mandatory)][string]$ClassName)
    Get-WmiObject -Namespace root\wmi -Class $ClassName -ErrorAction Stop
}

function Get-LenovoBiosSettingValue {
    param([Parameter(Mandatory)][string]$SettingName)
    $settings = Get-LenovoWmiObject -ClassName "Lenovo_BiosSetting"
    $match = $settings | Where-Object {
        $_.CurrentSetting -match "^$([regex]::Escape($SettingName)),"
    } | Select-Object -First 1
    if ($match) { return $match.CurrentSetting }
    return $null
}

function Get-ThirdPartyUEFICAStatus {
    $allBiosSettings = Get-WmiObject -Namespace root\wmi -Class Lenovo_BiosSetting -ErrorAction Stop | Select-Object -ExpandProperty CurrentSetting
    $allBiosSettings | Out-File "$env:TEMP\LenovoBIOSSettings.txt" -Force

    $thirdPartySetting = $allBiosSettings | Where-Object {
        $_ -match "3rd|Third|Microsoft.*UEFI.*CA|Allow.*UEFI.*CA|AllowMicrosoft3rdPartyUEFI"
    } | Select-Object -First 1

    if ($null -eq $thirdPartySetting) {
        return [PSCustomObject]@{ Found = $false; Status = "Unknown"; RawValue = $null }
    }
    if ($thirdPartySetting -match "Enable|Enabled|On") {
        return [PSCustomObject]@{ Found = $true; Status = "Enabled"; RawValue = $thirdPartySetting }
    }
    if ($thirdPartySetting -match "Disable|Disabled|Off") {
        return [PSCustomObject]@{ Found = $true; Status = "Disabled"; RawValue = $thirdPartySetting }
    }
    return [PSCustomObject]@{ Found = $true; Status = "Unknown"; RawValue = $thirdPartySetting }
}

function Get-SecureBootStatus {
    $currentValue = Get-LenovoBiosSettingValue -SettingName "SecureBoot"

    if ($null -eq $currentValue) {
        return [PSCustomObject]@{ Found = $false; Status = "NotFound"; RawValue = $null }
    }
    if ($currentValue -match "SecureBoot,Enable") {
        return [PSCustomObject]@{ Found = $true; Status = "Enabled"; RawValue = $currentValue }
    }
    if ($currentValue -match "SecureBoot,Disable") {
        return [PSCustomObject]@{ Found = $true; Status = "Disabled"; RawValue = $currentValue }
    }
    return [PSCustomObject]@{ Found = $true; Status = "Unknown"; RawValue = $currentValue }
}

function Set-LenovoBiosSetting {
    param(
        [Parameter(Mandatory)][string]$SettingName,
        [Parameter(Mandatory)][string]$Value
    )
    $setter = Get-LenovoWmiObject -ClassName "Lenovo_SetBiosSetting"
    $argument = "$SettingName,$Value"
    if ([string]::IsNullOrWhiteSpace($BiosAdminPassword)) {
        return $setter.SetBiosSetting($argument)
    } else {
        return $setter.SetBiosSetting("$argument,$BiosAdminPassword,ascii,us")
    }
}

function Save-LenovoBiosSettings {
    $saver = Get-LenovoWmiObject -ClassName "Lenovo_SaveBiosSettings"
    if ([string]::IsNullOrWhiteSpace($BiosAdminPassword)) {
        return $saver.SaveBiosSettings()
    } else {
        return $saver.SaveBiosSettings("$BiosAdminPassword,ascii,us")
    }
}

function Get-ResultText {
    param($ResultObject)
    if ($null -eq $ResultObject) { return "No result returned" }
    if ($ResultObject.PSObject.Properties.Name -contains "return") { return [string]$ResultObject.return }
    if ($ResultObject.PSObject.Properties.Name -contains "Return") { return [string]$ResultObject.Return }
    return ($ResultObject | Out-String).Trim()
}

function Test-ResultSuccess {
    param($ResultObject)
    $resultText = Get-ResultText $ResultObject
    return ($resultText -match "Success")
}

function Suspend-SystemBitLockerOnce {
    try {
        $osVolume = Get-BitLockerVolume -MountPoint $env:SystemDrive -ErrorAction Stop
        if ($osVolume.ProtectionStatus -eq "On") {
            Suspend-BitLocker -MountPoint $env:SystemDrive -RebootCount 1 | Out-Null
            Write-Log "BitLocker suspended for 1 reboot on $env:SystemDrive"
        } else {
            Write-Log "BitLocker is not enabled or already suspended on $env:SystemDrive"
        }
    } catch {
        Write-Log "BitLocker check skipped or failed: $($_.Exception.Message)"
    }
}

function Show-RestartPrompt {
    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -AssemblyName System.Drawing

    $form = New-Object System.Windows.Forms.Form
    $form.Text = "Restart Required - Secure Boot Remediation"
    $form.Size = New-Object System.Drawing.Size(460, 220)
    $form.StartPosition = "CenterScreen"
    $form.FormBorderStyle = "FixedDialog"
    $form.MaximizeBox = $false
    $form.MinimizeBox = $false
    $form.TopMost = $true

    $pictureBox = New-Object System.Windows.Forms.PictureBox
    $pictureBox.Image = ([System.Drawing.SystemIcons]::Warning).ToBitmap()
    $pictureBox.Size = New-Object System.Drawing.Size(48, 48)
    $pictureBox.Location = New-Object System.Drawing.Point(15, 20)
    $pictureBox.SizeMode = "StretchImage"
    $form.Controls.Add($pictureBox)

    $label = New-Object System.Windows.Forms.Label
    $label.Text = "BIOS settings have been updated successfully.`n`nA restart is required for the Secure Boot changes`nto take effect. Would you like to restart now?"
    $label.Size = New-Object System.Drawing.Size(360, 80)
    $label.Location = New-Object System.Drawing.Point(75, 15)
    $label.Font = New-Object System.Drawing.Font("Segoe UI", 9)
    $form.Controls.Add($label)

    $restartBtn = New-Object System.Windows.Forms.Button
    $restartBtn.Text = "Restart Now"
    $restartBtn.Size = New-Object System.Drawing.Size(130, 38)
    $restartBtn.Location = New-Object System.Drawing.Point(75, 140)
    $restartBtn.BackColor = [System.Drawing.Color]::FromArgb(0, 120, 212)
    $restartBtn.ForeColor = [System.Drawing.Color]::White
    $restartBtn.FlatStyle = "Flat"
    $restartBtn.Font = New-Object System.Drawing.Font("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)
    $restartBtn.DialogResult = [System.Windows.Forms.DialogResult]::Yes
    $form.Controls.Add($restartBtn)

    $deferBtn = New-Object System.Windows.Forms.Button
    $deferBtn.Text = "Defer Restart"
    $deferBtn.Size = New-Object System.Drawing.Size(130, 38)
    $deferBtn.Location = New-Object System.Drawing.Point(225, 140)
    $deferBtn.FlatStyle = "Flat"
    $deferBtn.Font = New-Object System.Drawing.Font("Segoe UI", 9)
    $deferBtn.DialogResult = [System.Windows.Forms.DialogResult]::No
    $form.Controls.Add($deferBtn)

    $form.AcceptButton = $restartBtn
    $form.CancelButton = $deferBtn

    return $form.ShowDialog()
}

# ==============================================================================
# MAIN
# ==============================================================================
try {
    Write-Log "===== Starting Lenovo Secure Boot Remediation ====="
    Write-Log "Log file path: $LogPath"

    if (-not (Test-IsAdmin)) { throw "Script must run as Administrator or SYSTEM." }

    $cs = Get-CimInstance Win32_ComputerSystem
    Write-Log "Manufacturer : $($cs.Manufacturer)"
    Write-Log "Model        : $($cs.Model)"

    if ($cs.Manufacturer -notmatch "Lenovo") { throw "This script is intended only for Lenovo devices." }

    $biosMode = (Get-ComputerInfo -Property BiosFirmwareType).BiosFirmwareType
    Write-Log "Firmware type: $biosMode"

    if ($biosMode -ne "UEFI") { throw "Device is not running in UEFI mode. Secure Boot cannot be enabled." }

    if ($SuspendBitLockerForNextReboot) { Suspend-SystemBitLockerOnce }

    $changesMade = $false

    # ----------------------------------------------------------------------
    # STEP 1: Check Microsoft 3rd Party UEFI CA status
    # ----------------------------------------------------------------------
    Write-Log "--- Checking Microsoft 3rd Party UEFI CA ---"
    $thirdPartyStatus = Get-ThirdPartyUEFICAStatus
    Write-Log "Found  : $($thirdPartyStatus.Found)"
    Write-Log "Status : $($thirdPartyStatus.Status)"
    Write-Log "Raw    : $($thirdPartyStatus.RawValue)"

    if (-not $thirdPartyStatus.Found) {
        throw "Microsoft 3rd Party UEFI CA setting not found in BIOS. Aborting."
    }
    if ($thirdPartyStatus.Status -eq "Unknown") {
        throw "Microsoft 3rd Party UEFI CA status is unknown. Aborting."
    }

    # ----------------------------------------------------------------------
    # STEP 2: Enable 3rd Party UEFI CA only if disabled
    # ----------------------------------------------------------------------
    if ($thirdPartyStatus.Status -eq "Disabled") {
        Write-Log "3rd Party UEFI CA is DISABLED - enabling it..."

        $thirdPartySettingName = ($thirdPartyStatus.RawValue -split ",")[0]
        Write-Log "Setting name: $thirdPartySettingName"

        $resultThirdParty = Set-LenovoBiosSetting -SettingName $thirdPartySettingName -Value "Enable"
        Write-Log "Result: $(Get-ResultText $resultThirdParty)"

        if (-not (Test-ResultSuccess $resultThirdParty)) {
            throw "Failed to enable Microsoft 3rd Party UEFI CA."
        }

        Write-Log "3rd Party UEFI CA enabled successfully."
        $changesMade = $true
    } else {
        Write-Log "3rd Party UEFI CA is already ENABLED - no change needed."
    }

    # ----------------------------------------------------------------------
    # STEP 3: Check Secure Boot status
    # ----------------------------------------------------------------------
    Write-Log "--- Checking Secure Boot Status ---"
    $secureBootStatus = Get-SecureBootStatus
    Write-Log "Found  : $($secureBootStatus.Found)"
    Write-Log "Status : $($secureBootStatus.Status)"
    Write-Log "Raw    : $($secureBootStatus.RawValue)"

    if (-not $secureBootStatus.Found) { throw "SecureBoot setting was not found in BIOS." }
    if ($secureBootStatus.Status -eq "Unknown") { throw "Unable to determine Secure Boot state. Raw value: $($secureBootStatus.RawValue)" }

    # ----------------------------------------------------------------------
    # STEP 4: Enable Secure Boot only if disabled
    # ----------------------------------------------------------------------
    if ($secureBootStatus.Status -eq "Disabled") {
        Write-Log "Secure Boot is DISABLED - enabling it..."

        $resultSecureBoot = Set-LenovoBiosSetting -SettingName "SecureBoot" -Value "Enable"
        Write-Log "Result: $(Get-ResultText $resultSecureBoot)"

        if (-not (Test-ResultSuccess $resultSecureBoot)) { throw "Failed to enable Secure Boot." }

        Write-Log "Secure Boot enabled successfully."
        $changesMade = $true
    } else {
        Write-Log "Secure Boot is already ENABLED - no change needed."
    }

    # ----------------------------------------------------------------------
    # STEP 5: Save BIOS settings if anything changed
    # ----------------------------------------------------------------------
    if ($changesMade) {
        Write-Log "--- Saving BIOS Settings ---"
        $saveResult = Save-LenovoBiosSettings
        Write-Log "Save result: $(Get-ResultText $saveResult)"

        if (-not (Test-ResultSuccess $saveResult)) { throw "Failed to save Lenovo BIOS settings." }
        Write-Log "BIOS settings saved. Reboot required to apply changes."

        # ----------------------------------------------------------------------
        # STEP 6: Restart decision
        # ----------------------------------------------------------------------
        if ($ForceRestart) {
            Write-Log "ForceRestart switch active. Restarting now..."
            Restart-Computer -Force
        } else {
            Write-Log "Prompting user for restart decision..."
            $restartChoice = Show-RestartPrompt

            if ($restartChoice -eq [System.Windows.Forms.DialogResult]::Yes) {
                Write-Log "User selected: Restart Now."
                Restart-Computer -Force
            } else {
                Write-Log "User selected: Defer Restart. Changes will apply on next reboot."
                Write-Host ""
                Write-Host "  [DEFERRED] Please restart the device at your earliest convenience." -ForegroundColor Yellow
                Write-Host "  Secure Boot changes will take effect after reboot." -ForegroundColor Yellow
                Write-Host ""
            }
        }
    } else {
        Write-Log "Device is already compliant. No BIOS changes were required."
        Write-Host ""
        Write-Host "  [COMPLIANT] Secure Boot and 3rd Party UEFI CA are already correctly configured." -ForegroundColor Green
        Write-Host "  No restart is needed." -ForegroundColor Green
        Write-Host ""
    }

    Write-Log "===== Secure Boot Remediation Completed Successfully ====="
    exit 0

} catch {
    Write-Log "ERROR: $($_.Exception.Message)"
    Write-Log "===== Secure Boot Remediation FAILED ====="
    exit 1
}